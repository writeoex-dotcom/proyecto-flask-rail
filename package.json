{
  "name": "petmarket-seguro",
  "version": "1.0.0",
  "description": "E-commerce de mascotas con Node.js, Express, MVC, MySQL y personalización por perfil de mascota.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --check server.js && find src public -name '*.js' -print0 | xargs -0 -n1 node --check",
    "db:sync": "node scripts/syncDatabase.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-flash": "^0.1.1",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "mysql2": "^3.11.0",
    "sequelize": "^6.37.3",
    "connect-session-sequelize": "^7.1.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18"
  }
}
