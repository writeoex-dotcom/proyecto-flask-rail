<section class="detail">
  <div class="product-image large"><%= product.category %></div>
  <div>
    <h1><%= product.name %></h1>
    <p><%= product.brand %> · <%= product.species %> · <%= product.lifeStage %></p>
    <p>Línea <%= product.lineType %> · <%= product.tags %></p>
    <strong>S/ <%= Number(product.price).toFixed(2) %></strong>
    <form method="post" action="/cart/add/<%= product.id %>">
      <button class="cta" type="submit">Agregar al carrito</button>
    </form>
  </div>
</section>
