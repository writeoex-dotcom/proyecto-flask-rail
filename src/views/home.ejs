<section class="hero">
  <div>
    <p class="eyebrow">Banner de publicidad</p>
    <h1>Todo para tu mascota, recomendado según su perfil</h1>
    <p>Compra comida comercial o medicada, shampoo, lociones, accesorios y juguetes con una experiencia personalizable.</p>
    <a class="cta" href="#productos">Ver ofertas</a>
  </div>
  <div class="ad-card">
    <span>-25%</span>
    <strong>Campaña de bienestar</strong>
    <p>Completa la huella de preferencias y priorizaremos productos para tu perro, gato, ave, hamster o pez.</p>
  </div>
</section>

<section class="preference-summary">
  <h2>Perfil de mascota</h2>
  <% if (preference) { %>
    <div class="chips">
      <span><%= preference.size || 'tamaño pendiente' %></span>
      <span><%= preference.species || 'mascota pendiente' %></span>
      <span><%= preference.lifeStage || 'edad pendiente' %></span>
      <span><%= preference.foodLine || 'línea pendiente' %></span>
      <span><%= preference.medicalCondition || 'condición pendiente' %></span>
    </div>
  <% } else { %>
    <p>Aún no hay preferencias. Toca la huella inferior para responder preguntas opcionales.</p>
  <% } %>
</section>

<section id="marcas" class="section">
  <h2>Marcas oficiales y reales</h2>
  <div class="brand-grid">
    <% brands.forEach((brand) => { %>
      <a class="brand-card" href="<%= brand.url %>" target="_blank" rel="noopener noreferrer">
        <div class="brand-logo"><%= brand.name[0] %></div>
        <h3><%= brand.name %></h3>
        <p><%= brand.kind %></p>
        <small><%= brand.description %></small>
        <div class="overlay">Acerca más de <%= brand.name %> →</div>
      </a>
    <% }) %>
  </div>
</section>

<section id="productos" class="section">
  <h2>Productos recomendados</h2>
  <div class="product-grid">
    <% products.forEach((product) => { %>
      <article class="product-card">
        <div class="product-image"><%= product.category %></div>
        <h3><%= product.name %></h3>
        <p><%= product.brand %> · <%= product.species %> · <%= product.lifeStage %></p>
        <p class="tags"><%= product.lineType %> · <%= product.tags %></p>
        <strong>S/ <%= Number(product.price).toFixed(2) %></strong>
        <div class="actions">
          <a href="/product/<%= product.id %>">Ver</a>
          <form method="post" action="/cart/add/<%= product.id %>"><button type="submit">Agregar</button></form>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<button class="paw-button" type="button" data-open-preferences>🐾</button>
<div class="modal" data-preferences-modal hidden>
  <form class="modal-card" method="post" action="/preferences">
    <button class="close" type="button" data-close-preferences>×</button>
    <h2>Personaliza con la huella</h2>
    <label>Tamaño de mascota
      <select name="size"><option value="">Sin responder</option><option value="pequeña">Pequeña: aves, hamsters, peces</option><option value="mediano">Mediano: gato o perro</option><option value="grande">Grande</option></select>
    </label>
    <label>Tipo de mascota
      <select name="species"><option value="">Sin responder</option><option value="perro">Perro</option><option value="gato">Gato</option><option value="ave">Ave</option><option value="hamster">Hamster</option><option value="pez">Pez</option></select>
    </label>
    <label>Edad
      <select name="ageRange"><option value="">Sin responder</option><option value="menos_1">Menos de 1 año: cachorro</option><option value="1_6">1 a 6 años: adulto</option><option value="mas_6">Más de 6 años: adulto mayor</option></select>
    </label>
    <label>Línea de comida
      <select name="foodLine"><option value="">Sin responder</option><option value="comercial">Comercial</option><option value="medicada">Medicada</option></select>
    </label>
    <label>Condición medicada
      <select name="medicalCondition"><option value="">Ninguna / no sé</option><option>renal</option><option>hepática</option><option>cardíaca</option><option>urinaria</option><option>sobrepeso</option><option>gastrointestinal</option><option>osteoarticular</option><option>cáncer</option><option>dermatológico</option></select>
    </label>
    <label>Shampoo: marca o línea <input name="shampooBrand" placeholder="Ej. Pro Plan, comercial"></label>
    <label>Condición del pelo <input name="coatCondition" placeholder="Pelo corto, largo, sensible"></label>
    <label>Sensibilidad de piel para lociones <input name="lotionSkinSensitivity" placeholder="Normal, sensible, alérgica"></label>
    <label>Accesorio preferido <input name="accessoryType" placeholder="Placa, collarín, cama"></label>
    <label>Tamaño del juguete <select name="toySize"><option value="">Sin responder</option><option>pequeño</option><option>mediano</option><option>grande</option></select></label>
    <label>Dureza del juguete <select name="toyHardness"><option value="">Sin responder</option><option>suave</option><option>media</option><option>dura</option></select></label>
    <button class="cta" type="submit">Guardar preferencias</button>
  </form>
</div>
