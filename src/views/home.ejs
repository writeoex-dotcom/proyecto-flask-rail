<%
  const savedPreferences = typeof preferences !== 'undefined' ? preferences : (preference ? [preference] : []);
  const productSections = [
    {
      id: 'comida-comercial',
      icon: '🥣',
      eyebrow: 'Alimentación diaria',
      title: 'Comida comercial',
      description: 'Solo comida de línea comercial: alimento seco o diario para nutrición de rutina.',
      items: products.filter((product) => product.category === 'comida' && product.lineType === 'comercial'),
    },
    {
      id: 'comida-medicada',
      icon: '🩺',
      eyebrow: 'Líneas veterinarias',
      title: 'Comida medicada',
      description: 'Solo comida de línea medicada/veterinaria para condiciones específicas.',
      items: products.filter((product) => product.category === 'comida' && product.lineType === 'medicada'),
    },
    {
      id: 'higiene',
      icon: '🧴',
      eyebrow: 'Cuidado y limpieza',
      title: 'Shampoo y lociones',
      description: 'Otros productos de cuidado: no son línea comercial/medicada de comida.',
      items: products.filter((product) => ['shampoo', 'lociones'].includes(product.category)),
    },
    {
      id: 'accesorios',
      icon: '🏷️',
      eyebrow: 'Uso diario',
      title: 'Accesorios',
      description: 'Otros productos: placas, camas, collarines y elementos de confort.',
      items: products.filter((product) => product.category === 'accesorios'),
    },
    {
      id: 'juguetes',
      icon: '🎾',
      eyebrow: 'Juego seguro',
      title: 'Juguetes',
      description: 'Otros productos de entretenimiento organizados por tamaño y dureza.',
      items: products.filter((product) => product.category === 'juguetes'),
    },
  ].filter((section) => section.items.length);

  const crossSections = [
    { id: 'perros', icon: '🐕', eyebrow: 'Por mascota', title: 'Perros', description: 'Comida, cuidado, accesorios y juguetes para perro.', items: products.filter((product) => product.species === 'perro') },
    { id: 'gatos', icon: '🐈', eyebrow: 'Por mascota', title: 'Gatos', description: 'Alimento, cama y productos recomendados para gato.', items: products.filter((product) => product.species === 'gato') },
    { id: 'pequenas-mascotas', icon: '🐹', eyebrow: 'Por tamaño', title: 'Pequeñas mascotas', description: 'Opciones para aves, hamsters y mascotas pequeñas.', items: products.filter((product) => ['ave', 'hamster', 'pez'].includes(product.species) || product.tags.includes('pequeña')) },
    { id: 'cachorros', icon: '🐶', eyebrow: 'Por etapa', title: 'Cachorros', description: 'Productos para menos de 1 año.', items: products.filter((product) => product.lifeStage === 'cachorro') },
    { id: 'adulto-mayor', icon: '🧓', eyebrow: 'Por etapa', title: 'Adulto mayor', description: 'Productos para mascotas senior y necesidades sensibles.', items: products.filter((product) => product.lifeStage === 'adulto mayor') },
    { id: 'renal-urinario', icon: '💧', eyebrow: 'Condición', title: 'Renal y urinario', description: 'Alimentos veterinarios para soporte renal o urinario.', items: products.filter((product) => product.tags.includes('renal') || product.tags.includes('urinaria')) },
    { id: 'digestivo-cardiaco', icon: '❤️', eyebrow: 'Condición', title: 'Digestivo y cardíaco', description: 'Opciones gastrointestinales y cardíacas.', items: products.filter((product) => product.tags.includes('gastrointestinal') || product.tags.includes('cardíaca')) },
    { id: 'piel-sensible', icon: '🌿', eyebrow: 'Cuidado', title: 'Piel sensible y dermatológico', description: 'Shampoo, lociones y alimentos con soporte dermatológico.', items: products.filter((product) => product.tags.includes('piel sensible') || product.tags.includes('dermatológico')) },
    { id: 'juguetes-resistencia', icon: '🦴', eyebrow: 'Juego', title: 'Juguetes por dureza', description: 'Juguetes suaves, medianos o duros según necesidad.', items: products.filter((product) => product.category === 'juguetes') },
    { id: 'confort-identificacion', icon: '🛏️', eyebrow: 'Accesorios', title: 'Confort e identificación', description: 'Camas, placas, collares y hábitat.', items: products.filter((product) => ['cama', 'placa', 'collarín', 'hábitat'].includes(product.productType)) },
  ].filter((section) => section.items.length);

  const pestelFactors = [
    ['Político', 'Mayor interés público por tenencia responsable, campañas de vacunación y registro municipal de mascotas.'],
    ['Económico', 'El cliente compara precio, promociones y delivery; se priorizan packs de ahorro y productos con valor comprobable.'],
    ['Social', 'La mascota se considera miembro de la familia, por eso crece la demanda de nutrición, cuidado, juguetes y bienestar.'],
    ['Tecnológico', 'E-commerce, WhatsApp, analítica de preferencias y recomendaciones permiten personalizar compra y recompra.'],
    ['Ecológico', 'Consumidores valoran empaques reciclables, rutas de reparto eficientes y productos durables.'],
    ['Legal', 'Se deben respetar etiquetado, protección al consumidor, datos personales y recomendación veterinaria para dietas medicadas.'],
  ];

  const segments = [
    ['Geográfica', 'Lima Metropolitana y ciudades urbanas con acceso a delivery, pagos digitales y clínicas veterinarias cercanas.'],
    ['Demográfica', 'Hogares de 18 a 55 años, estudiantes, parejas jóvenes, familias y adultos con perros o gatos.'],
    ['Psicográfica', 'Personas que valoran bienestar animal, conveniencia, asesoría y marcas confiables.'],
    ['Conductual', 'Compra recurrente mensual de alimento, búsqueda de ofertas, recompra por etapa de vida y productos para salud.'],
  ];

  const bcgItems = [
    ['Estrella', 'Comida medicada y recomendaciones personalizadas: alta demanda y diferenciación.'],
    ['Vaca', 'Alimento comercial para perro/gato: rotación constante y recompra mensual.'],
    ['Interrogante', 'Shampoos hipoalergénicos y juguetes premium: requieren educación y campañas.'],
    ['Perro', 'Accesorios genéricos sin personalización: baja diferenciación si no se agrupan por necesidad.'],
  ];

  const costItems = [
    ['Compra inicial de inventario', 'S/ 4,800', 'Alimentos, higiene, accesorios y juguetes de mayor rotación.'],
    ['Publicidad digital', 'S/ 1,200', 'Meta Ads, TikTok, Google y remarketing.'],
    ['Diseño y piezas promocionales', 'S/ 650', 'Banners, piezas para redes, flyers y fotografía básica.'],
    ['Operación y mano de obra', 'S/ 2,000', 'Atención, picking, empaque y soporte por WhatsApp.'],
    ['Logística local', 'S/ 900', 'Rutas de delivery y materiales de despacho.'],
    ['Tecnología y hosting', 'S/ 280', 'Dominio, hosting, base de datos y herramientas.'],
  ];

  const surveyCharts = [
    { title: 'Mascota principal en el hogar', type: 'doughnut', label: 'Encuestas', labels: ['Perro', 'Gato', 'Ambos', 'Otra'], values: [46, 28, 21, 5] },
    { title: 'Criterio de compra más importante', type: 'bar', label: 'Respuestas', labels: ['Precio', 'Marca', 'Delivery', 'Recomendación', 'Salud'], values: [29, 21, 18, 14, 18] },
    { title: 'Frecuencia de compra mensual', type: 'line', label: 'Respuestas', labels: ['1 vez', '2 veces', '3 veces', '4+ veces'], values: [24, 38, 25, 13] },
  ];
%>

<section class="hero section-block hero-section">
  <div>
    <p class="eyebrow">Banner de publicidad</p>
    <h1>Todo para tu mascota, recomendado según su perfil</h1>
    <p>Compra comida comercial o medicada, shampoo, lociones, accesorios y juguetes con una experiencia ordenada por secciones.</p>
    <div class="hero-actions">
      <a class="cta" href="#tienda">Ver tienda ordenada</a>
      <button class="secondary-button" type="button" data-open-preferences>Configurar preferencias</button>
    </div>
  </div>
  <div class="ad-card">
    <span>-25%</span>
    <strong>Campaña de bienestar</strong>
    <p>Completa hasta 2 referencias y priorizaremos productos coherentes para cada mascota.</p>
  </div>
</section>

<section id="nosotros" class="section section-block about-section">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Acerca de nosotros</p>
      <h2>Investigación de mercado y plan de marketing</h2>
      <p>Resumen académico y operativo para lanzar PetMarket Seguro como e-commerce de productos reales para mascotas, con recomendaciones por perfil y compra ordenada.</p>
    </div>
  </div>

  <div class="about-grid">
    <article class="about-card highlight-card">
      <p class="eyebrow">Capítulo 1: Introducción</p>
      <h3>PetMarket Seguro</h3>
      <p><strong>Misión:</strong> facilitar compras confiables de alimento, higiene, accesorios y juguetes para mascotas mediante catálogo verificado y recomendaciones por perfil.</p>
      <p><strong>Visión:</strong> ser una tienda digital referente en bienestar animal, trazabilidad de productos y experiencia simple para familias con mascotas.</p>
      <p><strong>Valores:</strong> confianza, cuidado animal, transparencia, innovación, responsabilidad y cercanía.</p>
      <p><strong>Objetivo general:</strong> lanzar una plataforma de venta online que conecte necesidades reales de perros, gatos y pequeñas mascotas con productos coherentes.</p>
      <ul>
        <li>Clasificar productos por especie, etapa, condición y tipo de uso.</li>
        <li>Educar al cliente sobre líneas comerciales, veterinarias y de cuidado.</li>
        <li>Validar canales digitales, promociones y recompra mensual.</li>
      </ul>
      <p><strong>Servicio a lanzar:</strong> e-commerce con filtros, catálogo trazable, carrito, preferencias por mascota y contenido de apoyo para decisiones de compra.</p>
    </article>

    <article class="about-card">
      <p class="eyebrow">Capítulo 2: Macroentorno</p>
      <h3>Análisis PESTEL</h3>
      <div class="mini-matrix">
        <% pestelFactors.forEach(([factor, detail]) => { %>
          <div><strong><%= factor %></strong><span><%= detail %></span></div>
        <% }) %>
      </div>
      <p class="source-note">Impacto: el entorno favorece una tienda digital con precios claros, delivery, fuentes reales y advertencias para alimentos veterinarios.</p>
    </article>
  </div>

  <div class="about-grid three">
    <article class="about-card">
      <p class="eyebrow">Capítulo 3</p>
      <h3>Segmentación y consumidor</h3>
      <% segments.forEach(([name, detail]) => { %>
        <p><strong><%= name %>:</strong> <%= detail %></p>
      <% }) %>
      <p><strong>Perfil clave:</strong> comprador digital que busca ahorro, confianza, entrega rápida y productos adecuados para edad, especie o condición.</p>
    </article>

    <article class="about-card">
      <p class="eyebrow">Capítulo 4: Producto</p>
      <h3>Marketing mix</h3>
      <p><strong>Características:</strong> catálogo verificado, recomendaciones, etiquetas, carrito y fuentes por producto.</p>
      <p><strong>Diferenciadores:</strong> separación clara entre comercial, medicada, higiene, accesorios y juguetes.</p>
      <p><strong>Diseño y marca:</strong> identidad cálida, ícono de huella, colores naranja/verde y mensajes de bienestar.</p>
      <div class="bcg-list">
        <% bcgItems.forEach(([label, detail]) => { %><span><strong><%= label %>:</strong> <%= detail %></span><% }) %>
      </div>
    </article>

    <article class="about-card">
      <p class="eyebrow">Plaza, promoción y precio</p>
      <h3>Estrategia comercial</h3>
      <p><strong>Plaza:</strong> web, redes sociales, WhatsApp, marketplaces y alianzas con veterinarias o pet shops locales.</p>
      <p><strong>Logística:</strong> cobertura inicial urbana, despacho por zonas, combos mensuales y seguimiento de recompra.</p>
      <p><strong>Promoción:</strong> ATL local, BTL con activaciones en veterinarias y digital con contenido educativo, influencers pet friendly y remarketing.</p>
      <p><strong>Precio:</strong> estrategia mixta de competencia y valor percibido; promociones de penetración para primera compra y bundles por necesidad.</p>
    </article>
  </div>

  <article class="about-card cost-card">
    <p class="eyebrow">Tabla de costos referencial</p>
    <h3>Presupuesto inicial de lanzamiento</h3>
    <div class="cost-table" role="table" aria-label="Costos referenciales de lanzamiento">
      <% costItems.forEach(([item, amount, note]) => { %>
        <div role="row"><span role="cell"><%= item %></span><strong role="cell"><%= amount %></strong><small role="cell"><%= note %></small></div>
      <% }) %>
    </div>
    <p class="source-note">Justificación: precios referenciales en soles para prototipo; la tienda debe actualizar costos reales de proveedor, margen, IGV, delivery y promociones antes de operar.</p>
  </article>

  <article class="about-card survey-card">
    <p class="eyebrow">Capítulo 5: Investigación de mercado</p>
    <h3>Encuestas online y hallazgos clave</h3>
    <p>Modelo de encuesta para 100 respuestas online: resultados demostrativos para validar el prototipo antes de una campaña real.</p>
    <ol class="survey-questions">
      <li>¿Qué mascota tienes en casa?</li><li>¿Con qué frecuencia compras alimento?</li><li>¿Cuál es tu presupuesto mensual?</li><li>¿Qué canal prefieres para comprar?</li><li>¿Qué factor pesa más: precio, marca, salud o delivery?</li><li>¿Comprarías comida medicada con recomendación veterinaria?</li><li>¿Te interesan combos mensuales?</li><li>¿Qué promociones te motivan?</li><li>¿Usas WhatsApp para coordinar compras?</li><li>¿Qué tan importante es ver fuentes reales del producto?</li>
    </ol>
    <div class="chart-grid market-charts">
      <% surveyCharts.forEach((chart) => { %>
        <div class="market-chart">
          <h4><%= chart.title %></h4>
          <canvas data-chart-type="<%= chart.type %>" data-chart-label="<%= chart.label %>" data-labels='<%- JSON.stringify(chart.labels) %>' data-values='<%- JSON.stringify(chart.values) %>'></canvas>
        </div>
      <% }) %>
    </div>
    <div class="findings-grid">
      <span><strong>Hallazgo 1:</strong> la recompra de alimento concentra la oportunidad de fidelización.</span>
      <span><strong>Hallazgo 2:</strong> el precio importa, pero la confianza y la salud justifican bundles y asesoría.</span>
      <span><strong>Hallazgo 3:</strong> el canal digital debe combinar web, WhatsApp y contenido educativo.</span>
    </div>
    <p class="source-note">Fuentes de contexto: <a href="https://www.ipsos.com/es-pe/entre-patas" target="_blank" rel="noopener noreferrer">Ipsos Perú</a> sobre tenencia y gasto en mascotas; <a href="https://www.gob.pe/institucion/inei/noticias/1193475-inei-incluira-la-tenencia-de-mascotas-en-hogares-en-sus-mediciones-a-partir-de-julio" target="_blank" rel="noopener noreferrer">INEI</a> sobre medición de tenencia/gasto; y <a href="https://www.peru-retail.com/comercio-electronico-en-peru-registra-un-crecimiento-del-21-2-en-2024-segun-capece/" target="_blank" rel="noopener noreferrer">CAPECE</a> sobre crecimiento del e-commerce peruano.</p>
  </article>
</section>

<section id="preferencias" class="preference-summary section-block">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Panel de preferencias</p>
      <h2>Hasta 2 mascotas con respuestas coherentes</h2>
      <p>El tamaño controla las especies disponibles para que la selección sea clara y cohesionada.</p>
    </div>
    <button class="cta" type="button" data-open-preferences>Configurar huella</button>
  </div>
  <% if (savedPreferences.length) { %>
    <div class="preference-cards">
      <% savedPreferences.forEach((item) => { %>
        <article class="preference-card">
          <strong><%= item.profileName || `Mascota ${item.preferenceSlot || 1}` %></strong>
          <div class="chips">
            <span><%= item.size || 'tamaño pendiente' %></span>
            <span><%= item.species || 'mascota pendiente' %></span>
            <span><%= item.lifeStage || 'edad pendiente' %></span>
            <span><%= item.foodLine || 'línea pendiente' %></span>
            <span><%= item.medicalCondition || 'sin condición' %></span>
          </div>
        </article>
      <% }) %>
    </div>
  <% } else { %>
    <p class="empty-state">Aún no hay preferencias. Toca la huella inferior para responder preguntas opcionales o cierra con X si no deseas configurar ahora.</p>
  <% } %>
</section>

<section id="marcas" class="section section-block">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Referencias externas</p>
      <h2>Marcas oficiales y reales</h2>
      <p>Cada marca enlaza a una fuente externa real; los productos muestran ficha oficial o fuente especializada para auditar coherencia.</p>
    </div>
  </div>
  <div class="brand-grid">
    <% brands.forEach((brand) => { %>
      <a class="brand-card" href="<%= brand.url %>" target="_blank" rel="noopener noreferrer">
        <div class="brand-logo"><%= brand.name[0] %></div>
        <h3><%= brand.name %></h3>
        <p><%= brand.kind %></p>
        <small><%= brand.description %></small>
        <div class="overlay">Acerca más de <%= brand.name %> →</div>
      </a>
    <% }) %>
  </div>
</section>

<section id="tienda" class="section section-block store-index">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Tienda organizada</p>
      <h2>Productos separados por sección</h2>
      <p>Comercial y medicada aplican específicamente a comida. Shampoo, accesorios y juguetes se separan como otros productos. Los precios son referenciales en soles y no reemplazan la validación del proveedor local.</p>
    </div>
  </div>
</section>

<p class="empty-state section" data-search-empty hidden>No encontramos productos con esa búsqueda. Prueba con comida, medicada, shampoo, accesorios o juguetes.</p>

<% const renderSection = (section, mode = 'principal') => { %>
  <section id="<%= section.id %>" class="section product-section section-block <%= mode === 'cruce' ? 'cross-section' : '' %>" data-product-section>
    <div class="section-heading product-section-heading">
      <div class="section-title-with-icon">
        <span><%= section.icon %></span>
        <div>
          <p class="eyebrow"><%= section.eyebrow %></p>
          <h2><%= section.title %></h2>
          <p><%= section.description %></p>
        </div>
      </div>
      <small><%= section.items.length %> producto<%= section.items.length === 1 ? '' : 's' %></small>
    </div>
    <div class="product-grid">
      <% section.items.forEach((product) => { %>
        <article class="product-card" data-product-card data-search="<%= `${product.name} ${product.brand} ${product.species} ${product.lifeStage} ${product.lineType} ${product.productType} ${product.category} ${product.tags}` %>">
          <div class="product-image"><%= product.category %></div>
          <h3><%= product.name %></h3>
          <p><%= product.brand %> · <%= product.species %> · <%= product.lifeStage %></p>
          <div class="tag-cloud" aria-label="Etiquetas de producto">
            <span><%= product.category %></span>
            <span><%= product.category === 'comida' ? `línea ${product.lineType}` : product.productType %></span>
            <span><%= product.species %></span>
            <span><%= product.lifeStage %></span>
            <% product.tags.split(',').filter(Boolean).forEach((tag) => { %><span><%= tag.trim() %></span><% }) %>
          </div>
          <% if (product.packageSize || product.sourceSummary) { %>
            <div class="product-source">
              <% if (product.packageSize) { %><small><strong>Presentación:</strong> <%= product.packageSize %></small><% } %>
              <% if (product.sourceSummary) { %><small><strong>Validación:</strong> <%= product.sourceSummary %></small><% } %>
            </div>
          <% } %>
          <strong>S/ <%= Number(product.price).toFixed(2) %> <small class="price-note">referencial</small></strong>
          <div class="actions">
            <a href="/product/<%= product.id %>">Ver</a>
            <% if (product.sourceUrl) { %><a href="<%= product.sourceUrl %>" target="_blank" rel="noopener noreferrer">Fuente</a><% } %>
            <form method="post" action="/cart/add/<%= product.id %>"><button type="submit">Agregar</button></form>
          </div>
        </article>
      <% }) %>
    </div>
  </section>
<% } %>

<% productSections.forEach((section) => renderSection(section)) %>

<section id="cruces" class="section section-block store-index">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Etiquetas y cruces</p>
      <h2>Explora por mascota, etapa, condición y necesidad</h2>
      <p>Algunos productos aparecen en más de una sección porque cruzan criterios: especie, edad, condición, cuidado o tipo de producto.</p>
    </div>
  </div>
</section>

<% crossSections.forEach((section) => renderSection(section, 'cruce')) %>

<button class="paw-button" type="button" data-open-preferences aria-label="Abrir panel de preferencias">🐾</button>
<div class="modal" data-preferences-modal hidden>
  <form class="modal-card preference-form" method="post" action="/preferences" data-preference-form>
    <button class="close" type="button" data-close-preferences aria-label="Cerrar preferencias">×</button>
    <div class="modal-title">
      <p class="eyebrow">Preferencias coherentes</p>
      <h2>Configura hasta 2 mascotas</h2>
      <p>Primero elige el tamaño. El formulario solo mostrará especies compatibles: pequeña = ave/hamster/pez, mediano = perro/gato, grande = perro. Puedes cerrar con X sin guardar.</p>
    </div>

    <fieldset>
      <legend>1. Identificación de la referencia</legend>
      <div class="form-grid two-columns">
        <label>Preferencia
          <select name="preferenceSlot">
            <option value="1">Mascota 1</option>
            <option value="2">Mascota 2</option>
          </select>
        </label>
        <label>Nombre de referencia
          <input name="profileName" placeholder="Ej. Luna, Rocky o Mascota 1" maxlength="80">
        </label>
      </div>
    </fieldset>

    <fieldset>
      <legend>2. Perfil base coherente</legend>
      <div class="form-grid two-columns">
        <label>Tamaño de mascota
          <select name="size" data-size-select>
            <option value="">Sin responder</option>
            <option value="pequeña">Pequeña: ave, hamster o pez</option>
            <option value="mediano">Mediano: gato o perro</option>
            <option value="grande">Grande: perro</option>
          </select>
        </label>
        <label>Tipo de mascota
          <select name="species" data-species-select>
            <option value="">Primero elige tamaño</option>
            <option value="perro" data-sizes="mediano,grande">Perro</option>
            <option value="gato" data-sizes="mediano">Gato</option>
            <option value="ave" data-sizes="pequeña">Ave</option>
            <option value="hamster" data-sizes="pequeña">Hamster</option>
            <option value="pez" data-sizes="pequeña">Pez</option>
          </select>
          <small class="field-hint" data-species-hint>La lista se ajusta al tamaño seleccionado.</small>
        </label>
        <label>Edad
          <select name="ageRange"><option value="">Sin responder</option><option value="menos_1">Menos de 1 año: cachorro</option><option value="1_6">1 a 6 años: adulto</option><option value="mas_6">Más de 6 años: adulto mayor</option></select>
        </label>

      </div>
    </fieldset>

    <div class="preference-accordion" data-preference-accordion>
      <details open>
        <summary><span>+</span> 3. Alimentación y salud</summary>
        <div class="form-grid two-columns">
          <label>Línea de comida
            <select name="foodLine" data-food-line-select><option value="">Sin responder</option><option value="comercial">Comercial</option><option value="medicada">Medicada / veterinaria</option></select><small class="field-hint" data-food-hint>La línea comercial/medicada aplica específicamente a comida.</small>
          </label>
          <label>Condición medicada
            <select name="medicalCondition" data-medical-condition-select><option value="">Ninguna / no sé</option><option value="renal">Renal</option><option value="hepática">Hepática</option><option value="cardíaca">Cardíaca</option><option value="urinaria">Urinaria</option><option value="sobrepeso">Sobrepeso</option><option value="gastrointestinal">Gastrointestinal</option><option value="osteoarticular">Osteoarticular</option><option value="cáncer">Cáncer</option><option value="dermatológico">Dermatológico</option></select>
          </label>
        </div>
      </details>

      <details>
        <summary><span>+</span> 4. Higiene y cuidado</summary>
        <div class="form-grid two-columns">
          <label>Shampoo o línea de cuidado
            <select name="shampooBrand"><option value="">Sin responder</option><option value="piel sensible">Piel sensible</option><option value="pelo largo">Pelo largo</option><option value="pelo corto">Pelo corto</option><option value="hipoalergénico">Hipoalergénico</option><option value="control olor">Control de olor</option></select>
          </label>
          <label>Condición del pelo
            <select name="coatCondition"><option value="">Sin responder</option><option value="pelo corto">Pelo corto</option><option value="pelo largo">Pelo largo</option><option value="piel sensible">Piel sensible</option><option value="dermatológico">Dermatológico</option><option value="muda frecuente">Muda frecuente</option></select>
          </label>
          <label>Sensibilidad de piel para lociones
            <select name="lotionSkinSensitivity"><option value="">Sin responder</option><option value="normal">Normal</option><option value="sensible">Sensible</option><option value="alérgica">Alérgica</option><option value="reseca">Reseca</option><option value="dermatológica">Dermatológica</option></select>
          </label>
        </div>
      </details>

      <details>
        <summary><span>+</span> 5. Accesorios y juego</summary>
        <div class="form-grid two-columns">
          <label>Accesorio preferido
            <select name="accessoryType"><option value="">Sin responder</option><option value="placa">Placa</option><option value="collar">Collar</option><option value="collarín">Collarín</option><option value="cama">Cama</option><option value="transportador">Transportador</option><option value="comedero">Comedero</option></select>
          </label>
          <label>Tamaño del juguete
            <select name="toySize"><option value="">Sin responder</option><option value="pequeño">Pequeño</option><option value="mediano">Mediano</option><option value="grande">Grande</option></select>
          </label>
          <label>Dureza del juguete
            <select name="toyHardness"><option value="">Sin responder</option><option value="suave">Suave</option><option value="media">Media</option><option value="dura">Dura</option></select>
          </label>
        </div>
      </details>
    </div>

    <div class="modal-actions">
      <button class="secondary-button" type="button" data-close-preferences>No configurar ahora</button>
      <button class="cta" type="submit">Guardar preferencia</button>
    </div>
  </form>
</div>
