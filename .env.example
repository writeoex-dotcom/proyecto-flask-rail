NODE_ENV=development
PORT=3000

# Railway MySQL: usa MYSQL_URL o DATABASE_URL si el servicio lo expone.
MYSQL_URL=
DATABASE_URL=

# Configuración local alternativa si no usas una URL completa.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=petmarket
DB_USER=root
DB_PASSWORD=password
DB_DIALECT=mysql
DB_LOGGING=false

SESSION_SECRET=cambia-esto
SECURE_COOKIES=false
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD_HASH=
VERIFICATION_CODE_TTL_MINUTES=10
