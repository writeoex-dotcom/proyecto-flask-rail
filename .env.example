NODE_ENV=development
PORT=3000

# Railway MySQL: en el servicio WEB agrega como Variable Reference:
# MYSQL_URL=${{MySQL.MYSQL_URL}}
# Render: agrega MYSQL_URL en Environment Variables con tu MySQL externo
MYSQL_URL=
DATABASE_URL=
MYSQL_PUBLIC_URL=
DATABASE_PUBLIC_URL=
DB_URL=

# Variables separadas que Railway MySQL también puede exponer.
# Para red privada Railway normalmente MYSQLHOST=mysql.railway.internal.
MYSQLHOST=
MYSQLPORT=3306
MYSQLDATABASE=
MYSQL_DATABASE=
MYSQLUSER=
MYSQLPASSWORD=
MYSQL_ROOT_PASSWORD=

# Configuración local alternativa si no usas una URL completa.
# En Railway NO copies DB_HOST=localhost; usa MYSQL_URL o MYSQLHOST.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=petmarket
DB_USER=root
DB_PASSWORD=password
DB_DIALECT=mysql
DB_LOGGING=false
DB_SSL=false
# Railway legacy puede requerir IPv6 para mysql.railway.internal; déjalo vacío para autodetectar.
MYSQL_DNS_RESULT_ORDER=
DB_CONNECT_TIMEOUT_MS=20000
# true actualiza columnas/índices existentes además de crear tablas faltantes.
DB_SYNC_ALTER=false

# 0 = reintentos infinitos en segundo plano. Útil para Railway mientras MySQL despierta.
DB_CONNECT_RETRIES=0
DB_CONNECT_RETRY_DELAY_MS=5000

SESSION_SECRET=cambia-esto
SESSION_TABLE_NAME=sessions
SECURE_COOKIES=false
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD_HASH=
VERIFICATION_CODE_TTL_MINUTES=10
